{
  "name": "claude-code-ref",
  "displayName": "Claude Code Reference",
  "description": "Copy file path and line range to clipboard for Claude Code CLI",
  "publisher": "Xin",
  "version": "0.3.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "ui"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-code-ref.copyReference",
        "title": "Copy Code Reference for Claude"
      },
      {
        "command": "claude-code-ref.copyExplorerReference",
        "title": "Copy File/Folder Reference for Claude"
      },
      {
        "command": "claude-code-ref.toggleAbsolutePath",
        "title": "Toggle Absolute Path Mode for Claude"
      }
    ],
    "keybindings": [
      {
        "command": "claude-code-ref.copyReference",
        "key": "alt+k",
        "when": "editorTextFocus"
      },
      {
        "command": "claude-code-ref.copyExplorerReference",
        "key": "alt+k",
        "when": "filesExplorerFocus"
      },
      {
        "command": "claude-code-ref.toggleAbsolutePath",
        "key": "alt+j"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.3.0"
  }
}
